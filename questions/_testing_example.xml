<?xml version="1.0" encoding="UTF-8"?>
<questestinterop xmlns="http://www.imsglobal.org/xsd/ims_qtiasv1p2">

  <rubric>
    <mattext>This is a demo quiz containing different question types.</mattext>
  </rubric>

  <!-- ==================== SINGLE CHOICE ==================== -->
  <item ident="q1" label="single-001">
    <presentation>
      <mattext>What is the capital of France?</mattext>
      <response_lid ident="R1" rcardinality="Single">
        <render_choice shuffle="Yes">
          <response_label ident="A1"><mattext>London</mattext></response_label>
          <response_label ident="A2"><mattext>Paris</mattext></response_label>
          <response_label ident="A3"><mattext>Berlin</mattext></response_label>
          <response_label ident="A4"><mattext>Madrid</mattext></response_label>
        </render_choice>
      </response_lid>
    </presentation>
    <resprocessing>
      <respcondition continue="No">
        <varequal respident="R1">A2</varequal>
      </respcondition>
    </resprocessing>
  </item>

  <!-- ==================== MULTIPLE CHOICE ==================== -->
  <item ident="q2" label="multi-002">
    <presentation>
      <mattext>Which of the following are programming languages? (Choose all that apply)</mattext>
      <response_lid ident="R2" rcardinality="Multiple">
        <render_choice shuffle="Yes">
          <response_label ident="B1"><mattext>Python</mattext></response_label>
          <response_label ident="B2"><mattext>HTML</mattext></response_label>
          <response_label ident="B3"><mattext>JavaScript</mattext></response_label>
          <response_label ident="B4"><mattext>CSS</mattext></response_label>
          <response_label ident="B5"><mattext>Java</mattext></response_label>
        </render_choice>
      </response_lid>
    </presentation>
    <resprocessing>
      <respcondition continue="No">
        <and>
          <varequal respident="R2">B1</varequal>
          <varequal respident="R2">B3</varequal>
          <varequal respident="R2">B5</varequal>
        </and>
      </respcondition>
    </resprocessing>
  </item>

  <!-- ==================== MATCHING / ASSOCIATION ==================== -->
  <item ident="q3" label="match-003">
    <presentation>
      <mattext>Match the following countries with their capitals:</mattext>
      <response_lid ident="R4a" rcardinality="Single">
        <render_choice shuffle="Yes">
          <response_label ident="A1"><mattext>France</mattext></response_label>
          <response_label ident="A2"><mattext>Japan</mattext></response_label>
          <response_label ident="A3"><mattext>Brazil</mattext></response_label>
        </render_choice>
      </response_lid>
      <response_lid ident="R4b" rcardinality="Single">
        <render_choice shuffle="Yes">
          <response_label ident="B1"><mattext>Tokyo</mattext></response_label>
          <response_label ident="B2"><mattext>Paris</mattext></response_label>
          <response_label ident="B3"><mattext>Brasília</mattext></response_label>
        </render_choice>
      </response_lid>
    </presentation>
    <resprocessing>
      <respcondition continue="No">
        <and>
          <varequal respident="R4a">A1</varequal>
          <varequal respident="R4b">B2</varequal>
        </and>
        <and>
          <varequal respident="R4a">A2</varequal>
          <varequal respident="R4b">B1</varequal>
        </and>
        <and>
          <varequal respident="R4a">A3</varequal>
          <varequal respident="R4b">B3</varequal>
        </and>
      </respcondition>
    </resprocessing>
  </item>

</questestinterop>
